# ============================================================
# WebRTC-Live 环境变量配置
# ============================================================

# Flask 服务配置
FLASK_APP=backend/app.py
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false
SECRET_KEY=webrtc-live-secure-random-key-2026

# SRS 流媒体服务器配置 (内部通信)
# 使用 docker-compose 中定义的服务名 webrtc-srs
SRS_API_BASE=http://webrtc-srs:1985

# WebRTC 媒体流地址 (外部访问)
# 宿主机 IP: 10.0.6.65, 端口: 8000 (SRS UDP)
SRS_STREAM_URL=webrtc://10.0.6.65:8000/live/livestream

# SSL 证书配置 (可选，通常由 NPM 容器处理)
# SSL_CERT=/app/ssl/server.crt
# SSL_KEY=/app/ssl/server.key
