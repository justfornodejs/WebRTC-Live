# ============================================================
# SRS 服务器地址（Flask → SRS 内部通信，使用 HTTP）
# 注意：不是 HTTPS！SRS 不再需要 SSL
# ============================================================
SRS_API_BASE=http://192.168.1.100:1985
SRS_STREAM_URL=webrtc://192.168.1.100:1985/live/livestream

# ============================================================
# Flask 配置
# ============================================================
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false

# ============================================================
# SSL 证书路径（Flask 对外提供 HTTPS）
# 放在 ssl/ 目录下会自动检测，也可手动指定路径
# ============================================================
# SSL_CERT=./ssl/server.crt
# SSL_KEY=./ssl/server.key

# 安全配置
SECRET_KEY=change-me-in-production
